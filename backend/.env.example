# ============================================================
#  Screvyn Environment Variables
# ============================================================
#  SETUP: Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  NEVER commit the .env file. Only .env.example is in git.
# ============================================================

# Gemini API — get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# GitHub App (Phase 6 — leave blank for now)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# Redis (Phase 6 — leave blank for now)
REDIS_URL=

# Firebase (Phase 7 — leave blank for now)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# Notifications (Phase 7 — leave blank for now)
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM=reviews@screvyn.dev

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
